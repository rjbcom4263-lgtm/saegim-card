rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 스티커 도안: 로그인한 사용자만 읽기/쓰기
    match /sticker-designs/{fileName} {
      allow read, write: if request.auth != null;
    }
    // BMT 사진/음성: 누구나 읽기, 10MB 이하 쓰기 허용
    match /bmt/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024;
    }
    // 가든 에셋: 누구나 읽기, 관리자만 쓰기
    match /garden_assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in {
          "rjbcom4263@gmail.com": true
        };
    }
    // 나머지는 차단
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
